  // Replace the existing mousemove event handler with this improved version
document.addEventListener('mousemove', function(e) {
  const cards = document.querySelectorAll('.card');
  
  cards.forEach(card => {
    const rect = card.getBoundingClientRect();
    const centerX = rect.left + rect.width / 2;
    const centerY = rect.top + rect.height / 2;
    
    // Calculate distance from mouse to card center
    const distX = e.clientX - centerX;
    const distY = e.clientY - centerY;
    
    // Only apply effect if mouse is within reasonable distance
    const maxDist = Math.max(rect.width, rect.height) * 1.5;
    const dist = Math.sqrt(distX * distX + distY * distY);
    
    if (dist < maxDist) {
      // Calculate rotation based on mouse position (subtle effect)
      const rotateY = distX * 0.03; // horizontal tilt
      const rotateX = -distY * 0.03; // vertical tilt
      
      // Apply 3D rotation
      card.style.transform = `perspective(1000px) rotateY(${rotateY}deg) rotateX(${rotateX}deg)`;
      
      // Position the glow element
      const glow = card.querySelector('.card-front .glow');
      if (glow) {
        const cardFront = card.querySelector('.card-front');
        const frontRect = cardFront.getBoundingClientRect();
        
        // Calculate position within the card front
        const mouseX = e.clientX - frontRect.left;
        const mouseY = e.clientY - frontRect.top;
        
        if (mouseX > 0 && mouseX < frontRect.width && mouseY > 0 && mouseY < frontRect.height) {
          glow.style.left = `${mouseX - 75}px`;
          glow.style.top = `${mouseY - 75}px`;
          glow.style.opacity = '0.3';
        } else {
          // Center the glow if mouse is outside
          glow.style.left = '50%';
          glow.style.top = '50%';
          glow.style.transform = 'translate(-50%, -50%)';
        }
      }
    }
  });
});

