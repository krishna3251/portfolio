// Helper function to add 3D tilt effect when cards come into view
function addScrollEffect() {
  const cards = document.querySelectorAll('.card');
  
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('card-in-view');
        setTimeout(() => {
          entry.target.style.transform = 'perspective(1000px) translateZ(0)';
        }, 100);
      } else {
        entry.target.classList.remove('card-in-view');
      }
    });
  }, { threshold: 0.2 });
  
  cards.forEach(card => {
    observer.observe(card);
  });
}

