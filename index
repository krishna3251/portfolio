  <script>
    // Enhanced Settings Panel with Drag and Resize functionality
    class PortfolioSettings {
      constructor() {
        this.panel = document.getElementById('settings-panel');
        this.overlay = document.getElementById('settings-overlay');
        this.toggleBtn = document.getElementById('toggle-settings');
        this.closeBtn = document.getElementById('close-settings');
        this.dragHandle = document.getElementById('drag-handle');
        this.resizeHandle = document.getElementById('resize-handle');
        
        this.isDragging = false;
        this.isResizing = false;
        this.dragOffset = { x: 0, y: 0 };
        this.resizeStart = { x: 0, y: 0, width: 0, height: 0 };
        
        this.init();
      }

      init() {
        // Settings panel toggle
        this.toggleBtn.addEventListener('click', () => this.showPanel());
        this.closeBtn.addEventListener('click', () => this.hidePanel());
        this.overlay.addEventListener('click', () => this.hidePanel());

        // Dragging functionality
        this.dragHandle.addEventListener('mousedown', (e) => this.startDrag(e));
        this.dragHandle.addEventListener('touchstart', (e) => this.startDrag(e), { passive: false });

        // Resizing functionality
        this.resizeHandle.addEventListener('mousedown', (e) => this.startResize(e));
        this.resizeHandle.addEventListener('touchstart', (e) => this.startResize(e), { passive: false });
        this.resizeHandle.addEventListener('touchmove', (e) => this.handleMove(e), { passive: false });
        this.resizeHandle.addEventListener('mousemove', (e) => this.handleMove(e));

        // Global mouse/touch events
        document.addEventListener('mousemove', (e) => this.handleMove(e));
        document.addEventListener('touchmove', (e) => this.handleMove(e), { passive: false });
        document.addEventListener('mouseup', () => this.endInteraction());
        document.addEventListener('touchend', () => this.endInteraction());

        // Prevent default drag behavior
        this.panel.addEventListener('dragstart', (e) => e.preventDefault());

        // Initialize color picker
        this.initColorPicker();
      }

      showPanel() {
        this.panel.classList.add('active');
        this.overlay.classList.add('active');
        document.body.style.overflow = 'hidden';
      }

      hidePanel() {
        this.panel.classList.remove('active');
        this.overlay.classList.remove('active');
        document.body.style.overflow = '';
      }

      startDrag(e) {
        e.preventDefault();
        this.isDragging = true;
        
        const clientX = e.clientX || e.touches[0].clientX;
        const clientY = e.clientY || e.touches[0].clientY;
        const rect = this.panel.getBoundingClientRect();
        
        this.dragOffset.x = clientX - rect.left;
        this.dragOffset.y = clientY - rect.top;
        
        this.panel.classList.add('dragging');
        document.body.classList.add('dragging');
      }

      startResize(e) {
        e.preventDefault();
        e.stopPropagation();
        this.isResizing = true;
        
        const clientX = e.clientX || e.touches[0].clientX;
        const clientY = e.clientY || e.touches[0].clientY;
        const rect = this.panel.getBoundingClientRect();
        
        this.resizeStart.x = clientX;
        this.resizeStart.y = clientY;
        this.resizeStart.width = rect.width;
        this.resizeStart.height = rect.height;
        
        this.panel.classList.add('resizing');
        document.body.classList.add('resizing');
      }

      handleMove(e) {
        if (!this.isDragging && !this.isResizing) return;
        
        e.preventDefault();
        const clientX = e.clientX || e.touches[0].clientX;
        const clientY = e.clientY || e.touches[0].clientY;

        if (this.isDragging) {
          const newX = clientX - this.dragOffset.x;
          const newY = clientY - this.dragOffset.y;
          
          // Constrain to viewport
          const maxX = window.innerWidth - this.panel.offsetWidth;
          const maxY = window.innerHeight - this.panel.offsetHeight;
          
          const constrainedX = Math.max(0, Math.min(newX, maxX));
          const constrainedY = Math.max(0, Math.min(newY, maxY));
          
          this.panel.style.left = constrainedX + 'px';
          this.panel.style.top = constrainedY + 'px';
          this.panel.style.right = 'auto';
        }

        if (this.isResizing) {
          const deltaX = clientX - this.resizeStart.x;
          const deltaY = clientY - this.resizeStart.y;
          
          const newWidth = Math.max(280, Math.min(600, this.resizeStart.width + deltaX));
          const newHeight = Math.max(200, Math.min(window.innerHeight * 0.8, this.resizeStart.height + deltaY));
          
          this.panel.style.width = newWidth + 'px';
          this.panel.style.height = newHeight + 'px';
        }
      }

      endInteraction() {
        if (this.isDragging) {
          this.isDragging = false;
          this.panel.classList.remove('dragging');
          document.body.classList.remove('dragging');
        }

        if (this.isResizing) {
          this.isResizing = false;
          this.panel.classList.remove('resizing');
          document.body.classList.remove('resizing');
        }
      }

      initColorPicker() {
        const colorPicker = document.getElementById('color-picker');
        colorPicker.addEventListener('change', (e) => {
          const color = e.target.value;
          document.documentElement.style.setProperty('--primary-color', color);
          const rgb = this.hexToRgb(color);
          document.documentElement.style.setProperty('--primary-glow', `rgba(${rgb.r}, ${rgb.g}, ${rgb.b}, 0.3)`);
        });
      }

      hexToRgb(hex) {
        const result = /^#?([a-f\d]{2})([a-f\d]{2})([a-f\d]{2})$/i.exec(hex);
        return result ? {
          r: parseInt(result[1], 16),
          g: parseInt(result[2], 16),
          b: parseInt(result[3], 16)
        } : { r: 0, g: 255, b: 234 };
      }
    }

    // Initialize the enhanced settings panel
    document.addEventListener('DOMContentLoaded', () => {
      new PortfolioSettings();
    });

    // Enhanced layout toggle function
    function toggleLayout(layout) {
      const buttons = document.querySelectorAll('.layout-btn');
      buttons.forEach(btn => btn.classList.remove('active'));
      event.target.closest('.layout-btn').classList.add('active');
      
      // Add your layout switching logic here
      console.log(`Switched to ${layout} layout`);
    }

    // Enhanced theme toggle function
    function toggleTheme() {
      const body = document.body;
      const icon = document.querySelector('#theme-toggle i');
      
      body.classList.toggle('light-theme');
      
      if (body.classList.contains('light-theme')) {
        icon.classList.remove('fa-moon');
        icon.classList.add('fa-sun');
      } else {
        icon.classList.remove('fa-sun');
        icon.classList.add('fa-moon');
      }
    }

    // Enhanced color update function
    function updateColor(color) {
      document.documentElement.style.setProperty('--primary-color', color);
      const rgb = hexToRgb(color);
      document.documentElement.style.setProperty('--primary-glow', `rgba(${rgb.r}, ${rgb.g}, ${rgb.b}, 0.3)`);
    }

    function hexToRgb(hex) {
      const result = /^#?([a-f\d]{2})([a-f\d]{2})([a-f\d]{2})$/i.exec(hex);
      return result ? {
        r: parseInt(result[1], 16),
        g: parseInt(result[2], 16),
        b: parseInt(result[3], 16)
      } : { r: 0, g: 255, b: 234 };
    }
